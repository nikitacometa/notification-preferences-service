{
  "name": "notification-preferences-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "dev": "node --env-file-if-exists=.env --watch --import tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,test}/**/*.ts\""
  },
  "dependencies": {
    "express": "^5.1.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
